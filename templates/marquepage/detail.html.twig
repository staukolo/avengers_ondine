{# templates/marquepage/detail.html.twig #}

{% extends 'marquepage/layout.html.twig' %}

{% block title %}Détail d'un marque-page{% endblock %}

{% block marquepage_content %}

    <h1>Détail d'un marque-page</h1>
    <table>
        <tr>
            <th>Libellé</th>
            <th>Valeur</th>
        </tr>
        <tr>
            <td>Id</td>
            <td>{{ marquepage.id }}</td>
        </tr>
        <tr>
            <td>Url</td>
            <td>{{ marquepage.url }}</td>
        </tr>
        <tr>
            <td>Date de création</td>
            <td>{{ marquepage.dateCreation|date('d/m/Y H:i:s') }}</td>
        </tr>
        <tr>
            <td>Commentaire</td>
            <td>{{ marquepage.commentaire }}</td>
        </tr>
        <tr>
        <td>Mots-clés</td>
        <td>
            {% for motCle in marquepage.motCles %}
                <span class="badge">{{ motCle.libelle }}</span>
            {% endfor %}
        </td>
        </tr>
    </table>
    <a href="{{ path('app_marquepages') }}">← Retour à la liste</a>

{% endblock %}