{# templates/marquepage/index.html.twig #}
{% extends 'marquepage/layout.html.twig' %}

{% block title %}Liste des marque-pages{% endblock %}

{% block marquepage_content %}

<h1>Liste complète des marque-pages</h1>
    <table>
        <tr>
            <th>Url</th>
            <th>Date de création</th>
            <th>Commentaire</th>
        </tr>
        {% for marquepage in marquepages %}
        <tr>
            {# <td><a href="{{ marquepage.url }}" class="url-link" target="_blank">
                        {{ marquepage.url|replace({'https://': '', 'http://': ''}) }}
                    </a></td> #}
            <td>
                <a href="{{ path('app_marquepages_detail', {id: marquepage.id}) }}">
                    {{ marquepage.url }}
                </a>
            </td>
            <td>{{ marquepage.dateCreation|date('d/m/Y') }}</td>
            <td>{{ marquepage.commentaire }}</td>
        </tr>
        {% endfor %}
    </table>

{% endblock %}
